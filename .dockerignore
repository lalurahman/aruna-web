# =============================================================================
# .dockerignore — files excluded from the Docker build context
# =============================================================================

# Git
.git
.gitignore

# Secrets — never bake into the image
.env
.env.backup
.env.production

# Dependencies — installed inside the builder stage
/node_modules
/vendor

# Frontend build output — built inside the builder stage
/public/build
/public/hot
/public/fonts-manifest.dev.json

# Generated Wayfinder TypeScript files — regenerated inside the builder stage
/resources/js/wayfinder
/resources/js/actions
/resources/js/routes

# Storage runtime files — mounted as Docker volumes at runtime
/storage/framework/cache
/storage/framework/sessions
/storage/framework/views
/storage/logs
/storage/pail

# Bootstrap cache — written at runtime by artisan cache commands
/bootstrap/cache/*.php

# Test files
/tests
phpunit.xml
.phpunit.cache
.phpunit.result.cache

# Dev / IDE files
.DS_Store
.fleet
.idea
.nova
.vscode
.zed
.phpactor.json
auth.json

# Misc
*.log
npm-debug.log
yarn-error.log
Homestead.json
Homestead.yaml
